# Open Design environment — copy to .env and fill in values.
#   cp .env.example .env

# REQUIRED: API token the daemon authenticates with.
# Generate one with:  openssl rand -hex 32
OD_API_TOKEN=

# Optional overrides (defaults applied in docker-compose.yml if unset).
