#OPEN_DESIGN_PORT=7456
#OPEN_DESIGN_ALLOWED_ORIGINS=http://127.0.0.1:7456
#OPEN_DESIGN_MEM_LIMIT=1384m
#NODE_OPTIONS=--max-old-space-size=192
#OD_CODEX_SANDBOX=
